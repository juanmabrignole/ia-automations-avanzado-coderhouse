      "name": "Chat Model (Groq) - Worker"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=JSON del Worker: {{ $json.output }}\nDías de viaje reales: {{ $('Datos del viaje (fijos)').item.json.dias_viaje }}\nPolítica vigente por día: ${{ $('Planner (incluye política)').item.json.politica_viaticos_dia }}",
        "options": {
          "systemMessage": "ROL: Sos el Critic que audita reembolsos de gastos de viaje antes de aprobarlos.\n\nOBJETIVO: Recibís el JSON del Worker y los datos originales del viaje (días de viaje y política vigente por día). Tu trabajo es RECALCULAR el monto esperado (días x política) y comparar contra el monto que puso el Worker.\n\nREGLAS:\n1. Si el monto del Worker coincide con tu recálculo (margen de $1 por redondeo), respondé APROBADO.\n2. Si NO coincide, respondé RECHAZADO y explicá la diferencia exacta en pesos.\n3. Nunca apruebes solo por verificar que el JSON tenga los campos: siempre recalculá el número.\n\nRespondé en este formato: RESULTADO: <APROBADO|RECHAZADO>\\nMOTIVO: <explicación breve con los números>",
          "maxIterations": 3
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2.2,
      "position": [
        840,
        260
      ],
      "id": "7247de68-2427-4d48-b3f7-4109c2134314",
      "name": "Critic (recalcula y compara)"
    },
    {
